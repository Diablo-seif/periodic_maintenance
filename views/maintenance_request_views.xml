<odoo>
    <data>
        <record id="equipment_request_form_inherit" model="ir.ui.view">
            <field name="name">equipment.request.form.inherit</field>
            <field name="model">maintenance.request</field>
            <field name="inherit_id" ref="maintenance.hr_equipment_request_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//sheet/*[1]" position="before">
                    <widget name="web_ribbon" title="Maintenance Plan" bg_color="text-bg-warning"
                            invisible="not check_maintenance_plan"/>
                </xpath>


                <xpath expr="//header/button[@name='archive_equipment_request']" position="before">
                    <button name="action_go_validate_spare_part"
                            string="Get Spare Part"
                            type="object"
                            class="oe_highlight"
                            invisible="0"
                    />

                    <button name="maintenance_request_plans"
                            string="Maintenance Request Plans"
                            type="object"
                            class="oe_highlight"
                            invisible="1"
                    />



                </xpath>
                <xpath expr="//field[@name='equipment_id']" position="before">

                        <field name="check_maintenance_plan" readonly="0" class="oe_inline" invisible="1"/>
                        <field name="done" readonly="0" class="oe_inline" invisible="1"/>

                </xpath>

                <xpath expr="//field[@name='priority']" position="before">


                    <label for="equipment_consumption"
                           invisible="maintenance_type != 'preventive' or type_of_maintenance != 'kilometers'"/>
                    <div class="o_row"
                         invisible="maintenance_type != 'preventive' or type_of_maintenance  != 'kilometers'">
                        <field name="equipment_consumption" class="oe_inline"/>
                        <span class="ml8" invisible="type_of_maintenance  != 'kilometers'">KiloMeters</span>
                    </div>
                </xpath>

                <xpath expr="//notebook" position="inside">

                    <page string="Equipment">
                        <group>

                            <group>

                                <field name="orders_spare_parts" readonly="1"/>
                                <field name="done" readonly="1"/>
                                <field name="equipment_id" readonly="1" options="{'no_open': True}"/>
                                <field name="type_of_maintenance" readonly="1"/>
                            </group>
                            <group>
                                <field name="expected_mtbf" readonly="1"/>
                                <field name="tasks" readonly="1"/>

                            </group>

                        </group>
                    </page>

                    <page string="Orders Spare Parts">
                                                <field name="orders_spare_parts"  invisible="1"/>

                        <field name="maintenance_request_line_ids" invisible="orders_spare_parts == True">
                            <list editable="bottom">
                                <field name="product_id"/>
                                <field name="quantity"/>
                                <field name="qty_available"/>
                                <field name="difference"/>
                            </list>
                        </field>

                        <field name="maintenance_request_line_ids" invisible="orders_spare_parts != True">

                            <list no_open="1" create="0" delete="0">
                                <field name="product_id"/>
                                <field name="quantity" optional="hide"/>
                            </list>

                        </field>
                    </page>

                </xpath>

            </field>
        </record>


    </data>

</odoo>
